<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<AnchorPane prefHeight="680.0" prefWidth="1020.0" minHeight="480.0" minWidth="660.0"
    stylesheets="@../../css/dark-theme.css"
    xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.smartlibrary.ui.reservelist.ReserveListController">
  <VBox spacing="18.0" styleClass="card"
        AnchorPane.topAnchor="0.0" AnchorPane.bottomAnchor="0.0"
        AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
    <HBox alignment="CENTER_LEFT" spacing="16.0">
      <VBox spacing="4.0" HBox.hgrow="ALWAYS">
        <Label text="RESERVAS" styleClass="label-eyebrow"/>
        <Label text="Reservas activas" styleClass="label-title"/>
      </VBox>
      <Label fx:id="lblCount" text="0 reservas" styleClass="label-count-chip"/>
      <Button text="Actualizar" styleClass="btn-icon" onAction="#handleRefresh"/>
    </HBox>
    <Label text="Libros con reserva pendiente." styleClass="label-subtitle"/>
    <Separator/>
    <TableView fx:id="tableReserves" VBox.vgrow="ALWAYS">
      <columns>
        <TableColumn fx:id="colUser"   text="Usuario"       prefWidth="200.0"/>
        <TableColumn fx:id="colBook"   text="Libro"         prefWidth="250.0"/>
        <TableColumn fx:id="colDate"   text="Fecha reserva" prefWidth="160.0"/>
        <TableColumn fx:id="colActive" text="Estado"        prefWidth="110.0"/>
      </columns>
      <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
    </TableView>
  </VBox>
</AnchorPane>
