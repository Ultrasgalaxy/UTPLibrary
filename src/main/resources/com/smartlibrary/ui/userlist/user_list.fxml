<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<AnchorPane prefHeight="680.0" prefWidth="1040.0" minHeight="480.0" minWidth="680.0"
    stylesheets="@../../css/dark-theme.css"
    xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.smartlibrary.ui.userlist.UserListController">
  <VBox spacing="18.0" styleClass="card"
        AnchorPane.topAnchor="0.0" AnchorPane.bottomAnchor="0.0"
        AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
    <HBox alignment="CENTER_LEFT" spacing="16.0">
      <VBox spacing="4.0" HBox.hgrow="ALWAYS">
        <Label text="COMUNIDAD" styleClass="label-eyebrow"/>
        <Label text="Lista de usuarios" styleClass="label-title"/>
      </VBox>
      <Label fx:id="lblCount" text="0 usuarios" styleClass="label-count-chip"/>
      <Button text="Actualizar" styleClass="btn-icon" onAction="#handleRefresh"/>
    </HBox>
    <Label text="Todos los usuarios registrados en el sistema." styleClass="label-subtitle"/>
    <Separator/>
    <HBox spacing="10.0" alignment="CENTER_LEFT">
      <TextField fx:id="fieldSearch" styleClass="search-field" promptText="Buscar por nombre..." HBox.hgrow="ALWAYS" onKeyReleased="#handleSearch"/>
    </HBox>
    <TableView fx:id="tableUsers" VBox.vgrow="ALWAYS">
      <columns>
        <TableColumn fx:id="colName"       text="Nombre"         prefWidth="180.0"/>
        <TableColumn fx:id="colType"       text="Tipo"           prefWidth="110.0"/>
        <TableColumn fx:id="colMembership" text="Membresia"      prefWidth="200.0"/>
        <TableColumn fx:id="colLoans"      text="Prestamos act." prefWidth="130.0"/>
        <TableColumn fx:id="colMax"        text="Max. libros"    prefWidth="110.0"/>
      </columns>
      <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
    </TableView>
  </VBox>
</AnchorPane>
