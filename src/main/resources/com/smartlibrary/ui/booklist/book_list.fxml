<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<AnchorPane prefHeight="680.0" prefWidth="1000.0" minHeight="480.0" minWidth="640.0"
    stylesheets="@../../css/dark-theme.css"
    xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.smartlibrary.ui.booklist.BookListController">
  <VBox spacing="18.0" styleClass="card"
        AnchorPane.topAnchor="0.0" AnchorPane.bottomAnchor="0.0"
        AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
    <HBox alignment="CENTER_LEFT" spacing="16.0">
      <VBox spacing="4.0" HBox.hgrow="ALWAYS">
        <Label text="CATALOGO" styleClass="label-eyebrow"/>
        <Label text="Lista de libros" styleClass="label-title"/>
      </VBox>
      <Label fx:id="lblCount" text="0 libros" styleClass="label-count-chip"/>
      <Button fx:id="btnDelete" text="Eliminar seleccionado" styleClass="btn-danger" onAction="#handleDelete"/>
      <Button text="Actualizar" styleClass="btn-icon" onAction="#handleRefresh"/>
    </HBox>
    <Label text="Todos los libros registrados en el sistema." styleClass="label-subtitle"/>
    <Separator/>
    <HBox spacing="10.0" alignment="CENTER_LEFT">
      <TextField fx:id="fieldSearch" styleClass="search-field" promptText="Buscar por titulo o autor..." HBox.hgrow="ALWAYS" onKeyReleased="#handleSearch"/>
    </HBox>
    <Label fx:id="lblDeleteStatus" text="" styleClass="label-subtitle" wrapText="true"/>
    <TableView fx:id="tableBooks" VBox.vgrow="ALWAYS">
      <columns>
        <TableColumn fx:id="colTitle"  text="Titulo" prefWidth="280.0"/>
        <TableColumn fx:id="colAuthor" text="Autor"  prefWidth="220.0"/>
        <TableColumn fx:id="colStatus" text="Estado" prefWidth="140.0"/>
      </columns>
      <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
    </TableView>
  </VBox>
</AnchorPane>
